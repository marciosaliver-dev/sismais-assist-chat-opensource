# ============================================================
# SISMAIS ASSIST CHAT — Configuração de Variáveis de Ambiente
# ============================================================
#
# COMO USAR:
#   1. Copie este arquivo e renomeie para ".env"
#      (no terminal: cp .env.example .env)
#   2. Preencha cada valor com suas próprias credenciais
#   3. NUNCA envie o arquivo .env para o GitHub
#
# Dúvidas? Veja o guia completo em: README.md
# ============================================================


# ------------------------------------------------------------
# SUPABASE — Banco de dados e backend
# ------------------------------------------------------------
# Como obter: acesse https://supabase.com, crie um projeto gratuito,
# vá em Project Settings > API para encontrar estes valores.

VITE_SUPABASE_URL=https://SEU-PROJETO.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sua-chave-publica-anon-aqui

# ID do projeto (apenas os caracteres antes de ".supabase.co")
VITE_SUPABASE_PROJECT_ID=SEU-PROJETO-ID


# ------------------------------------------------------------
# MONITORAMENTO DE ERROS — Sentry (opcional)
# ------------------------------------------------------------
# Como obter: acesse https://sentry.io, crie um projeto React,
# e copie o DSN que aparece nas instruções de instalação.
# Deixe em branco para desativar o monitoramento de erros.

VITE_SENTRY_DSN=


# ============================================================
# SECRETS DAS EDGE FUNCTIONS (configurar no Supabase Dashboard)
# ============================================================
#
# Os itens abaixo NÃO ficam no arquivo .env do frontend.
# Eles devem ser cadastrados diretamente no Supabase:
#   Supabase Dashboard > Edge Functions > Secrets
#
# Copie os nomes abaixo e preencha com seus valores lá.
# ============================================================

# OPENROUTER_API_KEY
# Motor de IA — escolhe qual modelo de linguagem usar
# Como obter: https://openrouter.ai → API Keys → Create Key
# Valor: sk-or-v1-xxxxxxxxxxxxxxxxxxxx

# OPENAI_API_KEY
# Usado para criar embeddings (busca semântica na base de conhecimento)
# Como obter: https://platform.openai.com/api-keys → Create new secret key
# Valor: sk-xxxxxxxxxxxxxxxxxxxx

# SUPABASE_SERVICE_ROLE_KEY
# Chave de acesso administrativo ao seu banco Supabase
# Como obter: Supabase Dashboard > Project Settings > API > service_role key
# ⚠️ NUNCA exponha esta chave publicamente

# UAZAPI_BASE_URL
# Endereço do servidor UAZAPI (WhatsApp)
# Exemplo: https://meuservidor.uazapi.com
# Como obter: https://uazapi.com — contratar plano e instalar servidor

# UAZAPI_TOKEN
# Token de autenticação do UAZAPI
# Como obter: no painel do UAZAPI após instalar

# UAZAPI_INSTANCE_ID (opcional — pode ser configurado pela interface)
# ID da instância WhatsApp padrão
# Pode ser deixado em branco e configurado pelo painel do sistema


# ============================================================
# INTEGRAÇÕES OPCIONAIS (somente para usuários Sismais)
# ============================================================
# Estas integrações são exclusivas para quem usa os sistemas
# Sismais GL e Sismais Admin. Se você não usa esses sistemas,
# ignore completamente esta seção.

# SISMAIS_GL_SUPABASE_URL=
# SISMAIS_GL_SERVICE_ROLE_KEY=
# SISMAIS_ADMIN_SUPABASE_URL=
# SISMAIS_ADMIN_SERVICE_ROLE_KEY=
